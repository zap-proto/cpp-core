# This is a one-off test rule.

set -eu

echo findProvider special:ekam-interceptor
read INTERCEPTOR

if test "$INTERCEPTOR" = ""; then
  echo "error:  couldn't find intercept.so." >&2
  exit 1
fi

echo findProvider file:zap
read ZAP

if test "$ZAP" = ""; then
  echo "error:  couldn't find zap." >&2
  exit 1
fi

echo findProvider file:zapc-c++
read ZAPC_CXX

if test "$ZAPC_CXX" = ""; then
  echo "error:  couldn't find zapc-c++." >&2
  exit 1
fi

mkdir -p tmp/zap/bootstrap-test-tmp

INPUTS="zap/c++.zap zap/schema.zap zap/stream.zap zap/compiler/lexer.zap \
zap/compiler/grammar.zap zap/rpc.zap zap/rpc-twoparty.zap zap/persistent.zap \
zap/compat/json.zap"

SRC_INPUTS=""
for file in $INPUTS; do
  echo findProvider file:$file
  read srcfile
  SRC_INPUTS="$SRC_INPUTS $srcfile"
done

$ZAP compile --src-prefix=src -Isrc --no-standard-import \
    -o$ZAPC_CXX:tmp/zap/bootstrap-test-tmp $SRC_INPUTS

for file in $INPUTS; do
  for ext in h c++; do
    echo findProvider file:$file.$ext
    read srcfile
    test "x$srcfile" != x || (echo "missing: $file.$ext" >&2 && exit 1)
    diff -u $srcfile tmp/zap/bootstrap-test-tmp/$file.$ext >&2
  done
done

echo passed
