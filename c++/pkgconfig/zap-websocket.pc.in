prefix=@prefix@
exec_prefix=@exec_prefix@
libdir=@libdir@
includedir=@includedir@

Name: Zap WebSocket RPC
Description: WebSocket MessageStream for Zap
Version: @VERSION@
Libs: -L${libdir} -lzap-websocket
Requires: zap = @VERSION@ zap-rpc = @VERSION@ kj = @VERSION@ kj-async = @VERSION@ kj-http = @VERSION@
Cflags: -I${includedir}
