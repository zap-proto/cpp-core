prefix=@prefix@
exec_prefix=@exec_prefix@
libdir=@libdir@
includedir=@includedir@

Name: Zap
Description: Insanely fast serialization system compiler library
Version: @VERSION@
Libs: -L${libdir} -lzapc @PTHREAD_CFLAGS@ @PTHREAD_LIBS@ @STDLIB_FLAG@
Libs.private: @LIBS@
Requires: kj = @VERSION@
Cflags: -I${includedir} @PTHREAD_CFLAGS@ @STDLIB_FLAG@ @ZAP_LITE_FLAG@
